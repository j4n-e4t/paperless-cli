{
  "name": "paperless-cli",
  "version": "0.1.0",
  "description": "Terminal UI for browsing and searching Paperless-ngx documents",
  "type": "module",
  "bin": {
    "paperless-cli": "./dist/paperless-cli"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "bun build ./src/cli.tsx --target=node --outfile ./dist/paperless-cli && chmod +x ./dist/paperless-cli",
    "dev": "bun run ./src/cli.tsx",
    "start": "./dist/paperless-cli"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "ink": "5",
    "react": "18",
    "react-devtools-core": "file:./vendor/react-devtools-core"
  }
}
